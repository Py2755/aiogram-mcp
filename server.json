{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Py2755/aiogram-mcp",
  "description": "MCP server for aiogram Telegram bots — 30 tools, 7 resources, 3 prompts, event streaming",
  "title": "aiogram-mcp",
  "repository": {
    "url": "https://github.com/Py2755/aiogram-mcp",
    "source": "github"
  },
  "version": "0.7.1",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "aiogram-mcp",
      "version": "0.7.1",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BOT_TOKEN",
          "description": "Telegram Bot API token from @BotFather",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
